---
import { type HTTPCode } from '../data/http-codes';

interface Props {
  code: HTTPCode;
}

const { code } = Astro.props;
---

<div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] overflow-hidden">
  <div class="px-5 py-4 border-b border-[var(--color-border)] flex items-center justify-between">
    <h3 class="font-semibold flex items-center gap-2">
      <svg class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      Try It
    </h3>
    <button 
      id="try-it-btn"
      class="px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white text-sm font-medium rounded-lg transition-colors flex items-center gap-2"
    >
      <span>Send Request</span>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
    </button>
  </div>
  
  <div class="p-5 space-y-4">
    <!-- URL Display -->
    <div>
      <label class="text-xs font-medium text-[var(--color-muted)] uppercase tracking-wider mb-2 block">Request URL</label>
      <div class="flex items-center gap-2">
        <code class="flex-1 px-3 py-2 bg-[var(--color-bg)] rounded-lg text-sm font-mono border border-[var(--color-border)] overflow-x-auto">
          GET /http/{code.code}
        </code>
      </div>
    </div>
    
    <!-- Response -->
    <div>
      <label class="text-xs font-medium text-[var(--color-muted)] uppercase tracking-wider mb-2 block">Response</label>
      <div id="try-it-response" class="relative">
        <pre class="text-sm font-mono text-[var(--color-muted)]">Click "Send Request" to see the response...</pre>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ code: code.code }}>
  const btn = document.getElementById('try-it-btn');
  const responseContainer = document.querySelector('#try-it-response pre');
  
  btn?.addEventListener('click', async () => {
    if (!responseContainer) return;
    
    // Loading state
    btn.disabled = true;
    btn.innerHTML = `
      <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <span>Sending...</span>
    `;
    responseContainer.textContent = 'Loading...';
    
    try {
      const start = performance.now();
      const res = await fetch(`/http/${code}?no_redirect`);
      const latency = Math.round(performance.now() - start);
      
      let body;
      const contentType = res.headers.get('content-type');
      if (contentType?.includes('application/json')) {
        body = await res.json();
      } else {
        body = await res.text();
      }
      
      const headers = Object.fromEntries(res.headers.entries());
      const originalStatus = res.headers.get('x-original-status');

      const responseData = {
        status: originalStatus ? parseInt(originalStatus) : res.status,
        statusText: res.statusText,
        latency: `${latency}ms`,
        headers,
        body
      };
      
      responseContainer.textContent = JSON.stringify(responseData, null, 2);
    } catch (err) {
      responseContainer.textContent = `Error: ${err.message}`;
    } finally {
      btn.disabled = false;
      btn.innerHTML = `
        <span>Send Request</span>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      `;
    }
  });
</script>
