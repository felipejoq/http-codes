---
interface Props {
  placeholder?: string;
  id?: string;
}

const { placeholder = 'Search HTTP codes...', id = 'search-input' } = Astro.props;
---

<div class="relative">
  <label for={id} class="sr-only">Search HTTP status codes</label>
  <input
    type="text"
    id={id}
    name="q"
    class="search-input w-full px-4 py-3 pl-12 rounded-xl border border-(--color-border) bg-(--color-card) text-(--color-text) placeholder-(--color-muted) focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all"
    placeholder={placeholder}
    autocomplete="off"
  />
  <svg 
    class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-(--color-muted)" 
    fill="none" 
    viewBox="0 0 24 24" 
    stroke="currentColor"
  >
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
  </svg>
  <kbd class="absolute right-4 top-1/2 -translate-y-1/2 hidden sm:block px-2 py-0.5 text-xs rounded bg-(--color-code-bg) border border-(--color-border) text-(--color-muted)">
    /
  </kbd>
</div>

<script define:vars={{ id }}>
  const input = document.getElementById(id);
  
  // Keyboard shortcut
  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement?.tagName !== 'INPUT') {
      e.preventDefault();
      input?.focus();
    }
  });
  
  // Dispatch search event
  input?.addEventListener('input', (e) => {
    const query = e.target.value.toLowerCase();
    document.dispatchEvent(new CustomEvent('codes:search', { detail: { query } }));
  });
</script>
