---
import { categoryConfig, type HTTPCode } from '../data/http-codes';

interface Props {
  code: HTTPCode;
  showDescription?: boolean;
}

const { code, showDescription = true } = Astro.props;
const config = categoryConfig[code.category];
---

<a 
  href={`/codes/${code.code}`}
  class="code-card block rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-5 hover:border-[var(--color-muted)]/50"
>
  <div class="flex items-start gap-4">
    <div class={`flex-shrink-0 w-16 h-16 rounded-lg ${config.bgColor} ${config.borderColor} border flex items-center justify-center`}>
      <span class={`text-2xl font-bold ${config.color}`}>{code.code}</span>
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <h3 class="font-semibold text-lg truncate">{code.name}</h3>
        <span class={`text-xs px-2 py-0.5 rounded-full ${config.bgColor} ${config.color} border ${config.borderColor}`}>
          {config.label}
        </span>
      </div>
      {showDescription && (
        <p class="text-sm text-[var(--color-muted)] line-clamp-2">{code.description}</p>
      )}
    </div>
  </div>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
