---
const currentYear = new Date().getFullYear();

const footerLinks = [
  {
    title: 'Documentation',
    links: [
      { label: 'All Codes', href: '/codes' },
      { label: 'API Docs', href: '/docs' },
      { label: 'Quick Start', href: '/docs#quick-start' },
    ]
  },
  {
    title: 'Popular Codes',
    links: [
      { label: '200 OK', href: '/codes/200' },
      { label: '404 Not Found', href: '/codes/404' },
      { label: '500 Internal Server Error', href: '/codes/500' },
      { label: '418 I\'m a Teapot', href: '/codes/418' },
    ]
  },
  {
    title: 'API',
    links: [
      { label: '/http/200', href: '/http/200' },
      { label: '/http/404', href: '/http/404' },
      { label: '/http/500', href: '/http/500' },
    ]
  }
];
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-card)]">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-bold">
            H
          </div>
          <span class="font-bold text-lg">HTTP Echo</span>
        </a>
        <p class="text-sm text-[var(--color-muted)]">
          Complete HTTP status code reference and testing API. Free, fast, and developer-friendly.
        </p>
      </div>
      
      <!-- Links -->
      {footerLinks.map(section => (
        <div>
          <h3 class="font-semibold mb-4">{section.title}</h3>
          <ul class="space-y-2">
            {section.links.map(link => (
              <li>
                <a 
                  href={link.href}
                  class="text-sm text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    
    <div class="mt-12 pt-8 border-t border-[var(--color-border)] flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-[var(--color-muted)]">
        © {currentYear} HTTP Echo. Open source under MIT License.
      </p>
      <div class="flex items-center gap-4">
        <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
