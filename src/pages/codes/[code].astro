---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import TryIt from '../../components/TryIt.astro';
import CopyButton from '../../components/CopyButton.astro';
import { getHTTPCode, categoryConfig, getRelatedCodes, httpCodes } from '../../data/http-codes';

export function getStaticPaths() {
  return httpCodes.map(code => ({
    params: { code: code.code.toString() },
    props: { code },
  }));
}

const { code } = Astro.props;
const config = categoryConfig[code.category];
const relatedCodes = getRelatedCodes(code);

const title = `HTTP ${code.code} — ${code.name} | HTTP Echo`;
const description = code.description;

const apiUrl = `https://http.uncodigo.com/http/${code.code}`;
const curlExample = `curl -i ${apiUrl}`;
---

<BaseLayout title={title} description={description}>
  <Header slot="header" />
  
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm text-[var(--color-muted)] mb-6">
      <a href="/" class="hover:text-[var(--color-text)] transition-colors">Home</a>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
      <a href="/codes" class="hover:text-[var(--color-text)] transition-colors">Codes</a>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
      <span class="text-[var(--color-text)]">{code.code}</span>
    </nav>
    
    <!-- Header -->
    <div class="mb-8">
      <div class="flex flex-wrap items-start gap-4 mb-4">
        <div class={`w-24 h-24 rounded-2xl ${config.bgColor} ${config.borderColor} border flex items-center justify-center`}>
          <span class={`text-4xl font-bold ${config.color}`}>{code.code}</span>
        </div>
        <div class="flex-1">
          <div class="flex flex-wrap items-center gap-2 mb-2">
            <span class={`text-xs px-2 py-1 rounded-full ${config.bgColor} ${config.color} border ${config.borderColor}`}>
              {config.icon} {config.label}
            </span>
            {code.spec && (
              <a 
                href={code.specUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs px-2 py-1 rounded-full bg-[var(--color-card)] border border-[var(--color-border)] text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors flex items-center gap-1"
              >
                {code.spec}
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}
          </div>
          <h1 class="text-3xl sm:text-4xl font-bold mb-2">{code.name}</h1>
        </div>
      </div>
    </div>
    
    <!-- Description -->
    <div class="prose dark:prose-invert max-w-none mb-8">
      <p class="text-lg">{code.description}</p>
    </div>
    
    <!-- Common Use -->
    <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-6 mb-8">
      <h2 class="text-lg font-semibold mb-3 flex items-center gap-2">
        <svg class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Common Use
      </h2>
      <div class="prose dark:prose-invert prose-sm max-w-none">
        <p>{code.commonUse}</p>
      </div>
    </div>
    
    <!-- API Section -->
    <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-6 mb-8">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold flex items-center gap-2">
          <svg class="w-5 h-5 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          API Endpoint
        </h2>
        <CopyButton text={apiUrl} label="Copy URL" />
      </div>
      
      <div class="bg-[var(--color-bg)] rounded-lg p-4 border border-[var(--color-border)] mb-4 overflow-x-auto">
        <code class="text-sm font-mono">{apiUrl}</code>
      </div>
      
      <h3 class="text-sm font-medium text-[var(--color-muted)] uppercase tracking-wider mb-2">Example with curl</h3>
      <div class="relative">
        <pre class="text-sm"><code>{curlExample}</code></pre>
        <div class="absolute top-2 right-2">
          <CopyButton text={curlExample} label="Copy" />
        </div>
      </div>
    </div>
    
    <!-- Try It Widget -->
    <div class="mb-8">
      <TryIt code={code} />
    </div>
    
    <!-- Example -->
    {code.example && (
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-6 mb-8">
        <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Example
        </h2>
        
        <div class="space-y-4">
          <div>
            <h3 class="text-xs font-medium text-[var(--color-muted)] uppercase tracking-wider mb-2">Request</h3>
            <pre class="text-sm"><code>{code.example.request}</code></pre>
          </div>
          <div>
            <h3 class="text-xs font-medium text-[var(--color-muted)] uppercase tracking-wider mb-2">Response</h3>
            <pre class="text-sm"><code>{code.example.response}</code></pre>
          </div>
        </div>
      </div>
    )}
    
    <!-- Headers -->
    {code.headers && code.headers.length > 0 && (
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-6 mb-8">
        <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Related Headers
        </h2>
        
        <div class="space-y-4 prose dark:prose-invert prose-sm max-w-none">
          {code.headers.map(header => (
            <div class="border border-[var(--color-border)] rounded-lg p-4 not-prose">
              <code class="text-sm font-mono font-semibold text-blue-600 dark:text-blue-400">{header.name}</code>
              <p class="text-sm text-[var(--color-muted)] mt-1">{header.description}</p>
              <div class="mt-2 bg-[var(--color-bg)] rounded px-3 py-2">
                <code class="text-xs font-mono">{header.example}</code>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
    
    <!-- Related Codes -->
    {relatedCodes.length > 0 && (
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-6">
        <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
          Related Codes
        </h2>
        
        <div class="flex flex-wrap gap-2">
          {relatedCodes.map(related => (
            <a
              href={`/codes/${related.code}`}
              class={`px-4 py-2 rounded-lg ${categoryConfig[related.category].bgColor} ${categoryConfig[related.category].borderColor} border hover:opacity-80 transition-opacity`}
            >
              <span class={`font-bold ${categoryConfig[related.category].color}`}>{related.code}</span>
              <span class="text-sm text-[var(--color-muted)] ml-2">{related.name}</span>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
  
  <Footer slot="footer" />
</BaseLayout>
