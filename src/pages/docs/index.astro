---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CopyButton from '../../components/CopyButton.astro';

const title = 'API Documentation | HTTP Echo';
const description = 'Complete documentation for the HTTP Echo API. Learn how to test HTTP status codes with query parameters, custom headers, and more.';

const baseUrl = 'https://http.uncodigo.com';

const endpoints = [
  {
    method: 'GET',
    path: '/http/{code}',
    description: 'Returns the requested HTTP status code with JSON metadata'
  },
  {
    method: 'POST',
    path: '/http/{code}',
    description: 'Same as GET, accepts POST requests'
  },
  {
    method: 'PUT',
    path: '/http/{code}',
    description: 'Same as GET, accepts PUT requests'
  },
  {
    method: 'DELETE',
    path: '/http/{code}',
    description: 'Same as GET, accepts DELETE requests'
  },
  {
    method: 'PATCH',
    path: '/http/{code}',
    description: 'Same as GET, accepts PATCH requests'
  },
  {
    method: 'HEAD',
    path: '/http/{code}',
    description: 'Returns headers only, no body'
  },
  {
    method: 'OPTIONS',
    path: '/http/{code}',
    description: 'Returns CORS headers and allowed methods'
  }
];

const queryParams = [
  {
    name: 'delay',
    type: 'number (ms)',
    description: 'Delay the response by N milliseconds (max 30000)',
    example: '/http/200?delay=2000'
  },
  {
    name: 'body',
    type: 'string',
    description: 'Custom response body',
    example: '/http/200?body=Hello+World'
  },
  {
    name: 'content_type',
    type: 'string',
    description: 'Custom Content-Type header',
    example: '/http/200?content_type=text/plain'
  },
  {
    name: 'headers',
    type: 'JSON',
    description: 'Additional response headers as JSON object',
    example: '/http/200?headers={"X-Custom":"value"}'
  },
  {
    name: 'redirect_to',
    type: 'string (URL)',
    description: 'Destination URL for 3xx redirects',
    example: '/http/301?redirect_to=https://example.com'
  },
  {
    name: 'retry_after',
    type: 'number (seconds)',
    description: 'Value for Retry-After header (429, 503)',
    example: '/http/429?retry_after=60'
  },
  {
    name: 'allow',
    type: 'string',
    description: 'Allowed methods for 405 response',
    example: '/http/405?allow=GET,POST'
  }
];

const examples = [
  {
    name: 'curl',
    language: 'bash',
    code: `# Get a 200 OK response
curl -i ${baseUrl}/http/200

# Simulate a slow server
curl -i "${baseUrl}/http/200?delay=5000"

# Test rate limiting with retry info
curl -i "${baseUrl}/http/429?retry_after=60"

# Custom redirect
curl -i "${baseUrl}/http/301?redirect_to=https://example.com"

# Custom response body
curl -i "${baseUrl}/http/200?content_type=text/plain&body=Custom+response"`
  },
  {
    name: 'JavaScript (fetch)',
    language: 'javascript',
    code: `// Test a 404 response
const response = await fetch('${baseUrl}/http/404');
console.log(response.status); // 404
const data = await response.json();
console.log(data);

// With delay
const slowResponse = await fetch('${baseUrl}/http/200?delay=2000');

// Custom headers
const customResponse = await fetch('${baseUrl}/http/200?headers={"X-Custom":"value"}');
console.log(customResponse.headers.get('X-Custom')); // value`
  },
  {
    name: 'Python (requests)',
    language: 'python',
    code: `import requests

# Test a 500 error
response = requests.get('${baseUrl}/http/500')
print(response.status_code)  # 500
print(response.json())

# With query parameters
response = requests.get('${baseUrl}/http/200', params={
    'delay': 1000,
    'content_type': 'text/plain'
})`
  },
  {
    name: 'Go',
    language: 'go',
    code: `package main

import (
    "fmt"
    "net/http"
    "io"
)

func main() {
    resp, err := http.Get("${baseUrl}/http/418")
    if err != nil {
        panic(err)
    }
    defer resp.Body.Close()
    
    body, _ := io.ReadAll(resp.Body)
    fmt.Printf("Status: %d\\n", resp.StatusCode)
    fmt.Printf("Body: %s\\n", body)
}`
  }
];

const responseFormat = `{
  "code": 404,
  "name": "Not Found",
  "description": "The requested resource could not be found...",
  "spec": "RFC 9110, Section 15.5.5",
  "request": {
    "method": "GET",
    "url": "https://http.uncodigo.com/http/404",
    "headers": { ... }
  }
}`;

const corsInfo = `Access-Control-Allow-Origin: *
Access-Control-Allow-Methods: GET, POST, PUT, DELETE, PATCH, HEAD, OPTIONS
Access-Control-Allow-Headers: *`;
---

<BaseLayout title={title} description={description}>
  <Header slot="header" />
  
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm text-[var(--color-muted)] mb-6">
      <a href="/" class="hover:text-[var(--color-text)] transition-colors">Home</a>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
      <span class="text-[var(--color-text)]">API Documentation</span>
    </nav>
    
    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-3xl sm:text-4xl font-bold mb-4">API Documentation</h1>
      <div class="prose dark:prose-invert prose-lg max-w-2xl">
        <p>
          The HTTP Echo API allows you to test any HTTP status code with optional
          customization through query parameters. All endpoints are free, CORS-enabled,
          and require no authentication.
        </p>
      </div>
    </div>
    
    <!-- Base URL -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Base URL</h2>
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-6">
        <div class="flex items-center justify-between">
          <code class="text-lg font-mono">{baseUrl}</code>
          <CopyButton text={baseUrl} label="Copy" />
        </div>
      </div>
    </section>
    
    <!-- Endpoints -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Endpoints</h2>
      <div class="space-y-4">
        {endpoints.map(endpoint => (
          <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-5">
            <div class="flex flex-wrap items-center gap-3 mb-2">
              <span class={`http-method ${endpoint.method.toLowerCase()}`}>{endpoint.method}</span>
              <code class="font-mono text-lg">{endpoint.path}</code>
            </div>
            <p class="text-[var(--color-muted)]">{endpoint.description}</p>
          </div>
        ))}
      </div>
    </section>
    
    <!-- Query Parameters -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Query Parameters</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-[var(--color-border)]">
              <th class="pb-3 font-semibold">Parameter</th>
              <th class="pb-3 font-semibold">Type</th>
              <th class="pb-3 font-semibold">Description</th>
              <th class="pb-3 font-semibold">Example</th>
            </tr>
          </thead>
          <tbody>
            {queryParams.map((param, i) => (
              <tr class={`border-b border-[var(--color-border)] ${i % 2 === 0 ? 'bg-[var(--color-bg)]' : ''}`}>
                <td class="py-4">
                  <code class="text-blue-600 dark:text-blue-400 font-mono text-sm">{param.name}</code>
                </td>
                <td class="py-4 text-sm text-[var(--color-muted)]">{param.type}</td>
                <td class="py-4 text-sm">{param.description}</td>
                <td class="py-4">
                  <code class="text-xs font-mono bg-[var(--color-card)] px-2 py-1 rounded">{param.example}</code>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
    
    <!-- Quick Start -->
    <section id="quick-start" class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Quick Start</h2>
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-6 prose dark:prose-invert prose-sm max-w-none">
        <p>
          The simplest way to test the API is with curl:
        </p>
        <div class="relative">
          <pre class="text-sm"><code>curl https://http.uncodigo.com/http/200</code></pre>
          <div class="absolute top-2 right-2">
            <CopyButton text="curl https://http.uncodigo.com/http/200" label="Copy" />
          </div>
        </div>
      </div>
    </section>
    
    <!-- Examples -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Code Examples</h2>
      
      <div class="space-y-6">
        {examples.map(example => (
          <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] overflow-hidden">
            <div class="px-5 py-3 border-b border-[var(--color-border)] bg-[var(--color-bg)] flex items-center justify-between">
              <span class="font-medium">{example.name}</span>
              <CopyButton text={example.code} label="Copy" />
            </div>
            <div class="p-5 overflow-x-auto">
              <pre class="text-sm"><code>{example.code}</code></pre>
            </div>
          </div>
        ))}
      </div>
    </section>
    
    <!-- Response Format -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Response Format</h2>
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-6 prose dark:prose-invert prose-sm max-w-none">
        <p>
          By default, the API returns JSON with the following structure:
        </p>
        <pre class="text-sm"><code>{responseFormat}</code></pre>
      </div>
    </section>
    
    <!-- CORS -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">CORS</h2>
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-6 prose dark:prose-invert prose-sm max-w-none">
        <p>
          All API endpoints include permissive CORS headers, allowing you to use them
          from any origin, including browsers:
        </p>
        <pre class="text-sm"><code>{corsInfo}</code></pre>
      </div>
    </section>
    
    <!-- Rate Limiting -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Rate Limiting</h2>
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-6 prose dark:prose-invert prose-sm max-w-none">
        <p>
          The API includes rate limit headers in all responses:
        </p>
        <ul>
          <li><code>X-RateLimit-Limit</code> - Maximum requests allowed</li>
          <li><code>X-RateLimit-Remaining</code> - Requests remaining in current window</li>
          <li><code>X-RateLimit-Reset</code> - Unix timestamp when the limit resets</li>
        </ul>
        <p>
          For production use with higher limits, consider deploying your own instance.
        </p>
      </div>
    </section>
    
    <!-- Error Handling -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Error Handling</h2>
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-6 prose dark:prose-invert prose-sm max-w-none">
        <p>
          If you request an invalid status code, the API returns a 400 Bad Request:
        </p>
        <pre class="text-sm"><code>{`HTTP/1.1 400 Bad Request
Content-Type: application/json

{
  "error": "Invalid HTTP status code",
  "message": "Code 999 is not a recognized HTTP status code",
  "valid_range": "100-599 (plus common non-standard codes)",
  "docs": "https://http.uncodigo.com/codes"
}`}</code></pre>
      </div>
    </section>
    
    <!-- Use Cases -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Use Cases</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-5">
          <h3 class="font-semibold mb-2 flex items-center gap-2">
            <svg class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Error Handling Testing
          </h3>
          <p class="text-sm text-[var(--color-muted)]">
            Test how your application handles different HTTP error conditions without 
            needing to trigger real failures.
          </p>
        </div>
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-5">
          <h3 class="font-semibold mb-2 flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
            Mock Servers
          </h3>
          <p class="text-sm text-[var(--color-muted)]">
            Use in development when APIs aren't ready. Simulate success and error 
            responses to build resilient clients.
          </p>
        </div>
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-5">
          <h3 class="font-semibold mb-2 flex items-center gap-2">
            <svg class="w-5 h-5 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            CI/CD Testing
          </h3>
          <p class="text-sm text-[var(--color-muted)]">
            Include in automated test suites to verify your HTTP client logic 
            handles various status codes correctly.
          </p>
        </div>
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-5">
          <h3 class="font-semibold mb-2 flex items-center gap-2">
            <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            Learning & Teaching
          </h3>
          <p class="text-sm text-[var(--color-muted)]">
            Perfect for learning about HTTP status codes and demonstrating how 
            different codes behave in practice.
          </p>
        </div>
      </div>
    </section>
  </div>
  
  <Footer slot="footer" />
</BaseLayout>
